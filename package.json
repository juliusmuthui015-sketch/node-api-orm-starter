{
  "name": "node-orm",
  "version": "1.0.2",
  "description": "",
  "main": "server.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node build/server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "artisan": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts",
    "migrate": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts migrate",
    "migrate:fresh": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts migrate:fresh",
    "make:migration": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts make:migration",
    "db:seed": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts db:seed",
    "seed": "ts-node-dev -r tsconfig-paths/register --transpile-only src/database/seeders/seed.ts",
    "seed:mock": "ts-node-dev -r tsconfig-paths/register --transpile-only src/database/seeders/mock-cli.ts",
    "sync:permissions": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts permissions:sync",
    "test": "echo \"Error: no test specified\" && exit 1",
    "cache:cli": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts cache:list",
    "cache:clear": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts cache:clear",
    "key:generate": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts key:generate",
    "route:list": "ts-node-dev -r tsconfig-paths/register --transpile-only src/artisan.ts route:list"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "multer": "2.0.2",
    "mysql2": "^3.16.0",
    "nodemailer": "^8.0.1",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "ws": "^8.19.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.10.4",
    "@types/nodemailer": "^7.0.11",
    "@types/yargs": "^17.0.35",
    "prettier": "^3.7.4",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "unimport": "^5.6.0",
    "unplugin-auto-import": "^20.3.0"
  }
}
