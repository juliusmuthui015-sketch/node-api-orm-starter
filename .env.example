# Copy to .env and edit values for your environment
# Server
PORT=3000
NODE_ENV=development

# Database selection
# Options: mysql (default), mongodb
DB_CONNECTION=mysql
# (Deprecated alternative) DB_DRIVER= can also be used; prefer DB_CONNECTION
DB_DRIVER=

# Database (fill these with your DB credentials)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=*123*VYBZ
DB_NAME=HM
# If your MySQL uses a unix socket instead of TCP, set DB_SOCKET_PATH, e.g.:
# DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock

APP_URL=
FILE_URL_EXPIRES=3600
MAX_UPLOAD_SIZE=

# MongoDB (used when DB_CONNECTION=mongodb)
# Note: DB_NAME above is used as the database name when connecting to Mongo.
MONGO_URI=mongodb://localhost:27017
# or provide MONGODB_URI instead of MONGO_URI
MONGODB_URI=

# MongoDB Replica Set Configuration
# For standalone MongoDB (local dev): leave MONGO_REPLICA_SET empty, MONGO_RETRY_WRITES=false, MONGO_DIRECT_CONNECTION=true
# For replica set (production): set MONGO_REPLICA_SET=myReplicaSetName, MONGO_RETRY_WRITES=true, MONGO_DIRECT_CONNECTION=false
MONGO_REPLICA_SET=
# retryWrites requires replica set - set to false for standalone MongoDB to avoid "Transaction numbers" error
MONGO_RETRY_WRITES=false
# directConnection should be true for standalone, false for replica sets
MONGO_DIRECT_CONNECTION=true

# Pooling (MySQL only)
DB_POOL_LIMIT=10

# Cache configuration
# Options: file (default), database (or db), redis
CACHE_DRIVER=file
# Optional prefix to isolate cache keys
CACHE_PREFIX=rentivo

# Application key for encryption (32 bytes). Supports base64:... format
APP_KEY=base64:4mV5gN8s9Q0r7vL1h2Yx3Z0pQwR5tU2n8o9cV1b2a=

# JWT / Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Feature toggles
SKIP_DB=false
SKIP_CACHE=false
SYNC_PERMISSIONS_ON_START=false
ENABLE_MIGRATION_LOCK_ENDPOINT=false

# Migrations & locking
# Name for the distributed migration lock (MySQL uses GET_LOCK; Mongo uses a unique doc)
MIGRATION_LOCK_NAME=rentivo_migrations_lock
# Lock behavior (seconds, retries, backoff in ms)
MIGRATION_LOCK_TIMEOUT=10
MIGRATION_LOCK_RETRIES=5
MIGRATION_LOCK_BACKOFF_MS=1000
# Checksum policy for changed migration files: strict | warn | ignore
MIGRATION_CHECKSUM_POLICY=strict


# Redis (used if CACHE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=
REDIS_PASSWORD=

# Optional mock user (dev only)
MOCK_USER=

# DB socket (optional alternative to host/port)
DB_SOCKET_PATH=


MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_user
MAIL_PASSWORD=your_pass
MAIL_FROM=noreply@yourapp.com