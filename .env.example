# Server
PORT=3000
NODE_ENV=development

# Database (choose one backend in your db.config; these are typical MySQL vars)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=root
DB_PASSWORD=

# MongoDB alternative
# MONGO_URL=mongodb://localhost:27017/app

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=app
# For Redis driver
# REDIS_URL=redis://localhost:6379
# or:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# App key (enable cache encryption). Use `npm run key:generate` or tools/key-generate.
# Example: base64:oA3g2lQ9N2n1wT1tF7d8T3K2uV3f8X5vJ0V6h3Z6QnY=
APP_KEY=

# Feature flags
SKIP_DB=false
SKIP_CACHE=false
SYNC_PERMISSIONS_ON_START=false
ENABLE_MIGRATION_LOCK_ENDPOINT=false

