# Copy to .env and edit values for your environment
# Server
PORT=3000

# Database (fill these with your DB credentials)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=*123*VYBZ
DB_NAME=HM
# If your MySQL uses a unix socket instead of TCP, set DB_SOCKET_PATH, e.g.:
# DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock

# Pooling
DB_POOL_LIMIT=10

# Cache configuration
# Options: file (default), database (or db), redis
CACHE_DRIVER=file
# Optional prefix to isolate cache keys
CACHE_PREFIX=rentivo

# Application key for encryption (32 bytes). Supports base64:... format
APP_KEY=base64:4mV5gN8s9Q0r7vL1h2Yx3Z0pQwR5tU2n8o9cV1b2a=

# JWT / Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Feature toggles
SKIP_DB=false
SKIP_CACHE=false
SYNC_PERMISSIONS_ON_START=false
ENABLE_MIGRATION_LOCK_ENDPOINT=false
MIGRATION_LOCK_NAME=rentivo_migrations_lock

# Redis (used if CACHE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=
REDIS_PASSWORD=

# Optional mock user (dev only)
MOCK_USER=

# DB socket (optional alternative to host/port)
DB_SOCKET_PATH=
